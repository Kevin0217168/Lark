/* pages/clinic/clinic.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F8F5 0%, #F5F7FA 30%);
}

/* 自定义导航栏 */
.custom-navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(135deg, #00B894, #00A884);
  padding: 88rpx 32rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 184, 148, 0.2);
}

.navbar-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.clinic-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.badge-icon {
  font-size: 28rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 急诊入口 */
.emergency-section {
  padding: 24rpx;
}

.emergency-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF7675, #D63031);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(214, 48, 49, 0.3);
}

.emergency-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.emergency-icon {
  font-size: 64rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

.emergency-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.emergency-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.emergency-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.emergency-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 20rpx 32rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.btn-arrow {
  font-size: 24rpx;
  color: #FFFFFF;
}

/* 搜索筛选区 */
.search-section {
  padding: 0 24rpx 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #B2BEC3;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
}

.filter-tags {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.filter-tag {
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #636E72;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.filter-tag.active {
  background: linear-gradient(135deg, #00B894, #55EFC4);
  color: #FFFFFF;
  font-weight: 500;
}

/* 电子健康报告入口 */
.report-section {
  padding: 0 24rpx 24rpx;
}

.report-card {
  background: linear-gradient(135deg, #FFFFFF, #F8F9FA);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #00B894;
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.report-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.title-icon {
  font-size: 40rpx;
}

.report-badge {
  background: #FF7675;
  color: #FFFFFF;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.report-preview {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.preview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-label {
  font-size: 22rpx;
  color: #B2BEC3;
}

.preview-value {
  font-size: 26rpx;
  color: #2D3436;
  font-weight: 500;
}

.preview-value.has-advice {
  color: #FF7675;
  font-weight: 600;
}

.preview-divider {
  width: 1rpx;
  background: #DFE6E9;
}

.report-footer {
  padding-top: 24rpx;
  border-top: 1rpx solid #DFE6E9;
}

.report-tips {
  font-size: 22rpx;
  color: #636E72;
  line-height: 1.6;
}

/* 医生列表区 */
.doctors-section {
  padding: 0 24rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.section-sort {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.sort-text {
  font-size: 22rpx;
  color: #636E72;
}

.sort-icon {
  font-size: 24rpx;
}

/* 医生卡片 */
.doctors-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.doctor-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.doctor-card:active {
  transform: scale(0.98);
}

.doctor-main {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.doctor-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.doctor-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.online-status {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 28rpx;
  height: 28rpx;
  background: #FFFFFF;
  border-radius: 50%;
  padding: 4rpx;
}

.status-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.online-status.online .status-dot {
  background: #00B894;
  box-shadow: 0 0 8rpx rgba(0, 184, 148, 0.6);
}

.online-status.offline .status-dot {
  background: #B2BEC3;
}

.doctor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.doctor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
}

.doctor-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-certified {
  background: linear-gradient(135deg, #00B894, #55EFC4);
  color: #FFFFFF;
}

.tag-specialty {
  background: #74B9FF;
  color: #FFFFFF;
}

.doctor-title {
  font-size: 24rpx;
  color: #636E72;
}

.doctor-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-value {
  font-size: 24rpx;
  font-weight: 500;
  color: #2D3436;
}

.stat-divider {
  font-size: 20rpx;
  color: #B2BEC3;
}

.doctor-intro {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.doctor-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #DFE6E9;
}

.consult-price {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.price-label {
  font-size: 22rpx;
  color: #B2BEC3;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF7675;
}

.consult-btn {
  padding: 20rpx 40rpx;
  background: #B2BEC3;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.consult-btn.active {
  background: linear-gradient(135deg, #00B894, #55EFC4);
  box-shadow: 0 4rpx 12rpx rgba(0, 184, 148, 0.4);
}

.consult-btn::after {
  border: none;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #B2BEC3;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #B2BEC3;
  font-weight: 500;
}

.empty-tip {
  font-size: 24rpx;
  color: #B2BEC3;
}
