<!--pages/home/home.wxml-->
<view class="home-container">
  <!-- 顶部预警通知栏 -->
  <view class="alert-bar {{alertLevel}}">
    <view class="alert-icon">
      <text class="icon">{{alertIcon}}</text>
    </view>
    <view class="alert-content">
      <text class="alert-title">{{alertTitle}}</text>
      <text class="alert-message">{{alertMessage}}</text>
    </view>
    <view class="alert-close" bindtap="closeAlert">
      <text class="close-icon">×</text>
    </view>
  </view>

  <!-- 核心数据卡片区域 -->
  <view class="data-cards">
    <!-- 温湿度监测卡片 -->
    <view class="card incubator-card">
      <view class="card-header">
        <view class="card-title-wrap">
          <text class="card-icon">🌡️</text>
          <text class="card-title">智能孵化监测仪</text>
        </view>
        <view class="card-status online">
          <text class="status-dot"></text>
          <text class="status-text">在线</text>
        </view>
      </view>
      
      <view class="card-body">
        <view class="data-row">
          <view class="data-item temp">
            <view class="data-value">
              <text class="number">{{temp}}</text>
              <text class="unit">℃</text>
            </view>
            <view class="data-label">实时温度</view>
            <view class="data-precision">精度 ±0.5℃</view>
          </view>
          
          <view class="data-divider"></view>
          
          <view class="data-item humidity">
            <view class="data-value">
              <text class="number">{{humid}}</text>
              <text class="unit">%RH</text>
            </view>
            <view class="data-label">实时湿度</view>
            <view class="data-precision">精度 ±3%RH</view>
          </view>
        </view>
        
        <view class="update-time">
          <text>更新时间：{{updateTime}}</text>
        </view>
      </view>
      
      <view class="card-footer">
        <button class="btn btn-outline btn-sm" bindtap="refreshData">
          <text class="btn-icon">🔄</text>
          <text>刷新数据</text>
        </button>
      </view>
    </view>

    <!-- 设备控制卡片 -->
    <view class="card feeder-card">
      <view class="card-header">
        <view class="card-title-wrap">
          <text class="card-icon">🥣</text>
          <text class="card-title">智能喂鸟器</text>
        </view>
        <view class="card-status online">
          <text class="status-dot"></text>
          <text class="status-text">在线</text>
        </view>
      </view>
      
      <view class="card-body">
        <view class="food-status">
          <view class="food-info">
            <text class="food-label">余粮状态</text>
            <view class="food-level-wrap">
              <text class="food-level">{{foodLevel}}%</text>
              <view class="food-bar">
                <view class="food-progress" style="width: {{foodLevel}}%;"></view>
              </view>
            </view>
            <view style="font-size: 24rpx; color: #888; margin-top: 8rpx;">
              雷达测距：{{foodDistance}} cm
            </view>
          </view>
          <view class="food-alert {{foodLevel < 30 ? 'warning' : ''}}">
            <text>{{foodLevel < 30 ? '⚠️ 粮食不足' : '✅ 粮食充足'}}</text>
          </view>
        </view>
        
        <view class="feed-stats">
          <view class="stat-item">
            <text class="stat-value">{{todayFeedCount}}</text>
            <text class="stat-label">今日进食</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-value">{{lastFeedTime}}</text>
            <text class="stat-label">上次投喂</text>
          </view>
        </view>
        
        <view class="feed-control">
          <view class="control-title">定量投喂</view>
          <view class="control-row">
            <button class="feed-btn" bindtap="decreaseFood">
              <text>-</text>
            </button>
            <view class="feed-amount">
              <text class="amount-value">{{feedAmount}}</text>
              <text class="amount-unit">克</text>
            </view>
            <button class="feed-btn" bindtap="increaseFood">
              <text>+</text>
            </button>
          </view>
          <button class="btn btn-primary btn-block" bindtap="feedNow">
            <text class="btn-icon">🎯</text>
            <text>立即投喂</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 设备总览 -->
    <view class="card devices-card">
      <view class="card-header">
        <view class="card-title-wrap">
          <text class="card-icon">📱</text>
          <text class="card-title">设备总览</text>
        </view>
      </view>
      
      <view class="device-list">
        <view class="device-item" wx:for="{{devices}}" wx:key="id">
          <view class="device-icon">
            <text>{{item.icon}}</text>
          </view>
          <view class="device-info">
            <text class="device-name">{{item.name}}</text>
            <text class="device-status {{item.online ? 'online' : 'offline'}}">
              {{item.online ? '在线' : '离线'}}
            </text>
          </view>
          <view class="device-arrow">
            <text class="arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷功能入口 -->
  <view class="quick-actions">
    <view class="quick-item" bindtap="goToAI">
      <text class="quick-icon">🤖</text>
      <text class="quick-label">AI自检</text>
    </view>
    <view class="quick-item" bindtap="goToClinic">
      <text class="quick-icon">👨‍⚕️</text>
      <text class="quick-label">在线问诊</text>
    </view>
    <view class="quick-item" bindtap="goToReport">
      <text class="quick-icon">📊</text>
      <text class="quick-label">健康报告</text>
    </view>
    <view class="quick-item" bindtap="goToSettings">
      <text class="quick-icon">⚙️</text>
      <text class="quick-label">设备设置</text>
    </view>
  </view>
</view>
