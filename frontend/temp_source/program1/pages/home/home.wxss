/* pages/home/home.wxss */
.home-container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
}

/* 预警通知栏 */
.alert-bar {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-light);
  background: #ffffff;
}

.alert-bar.info {
  border-left: 4rpx solid var(--info-color);
}

.alert-bar.warning {
  border-left: 4rpx solid var(--warning-color);
}

.alert-bar.danger {
  border-left: 4rpx solid var(--danger-color);
}

.alert-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.alert-content {
  flex: 1;
}

.alert-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.alert-message {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.alert-close {
  padding: 8rpx;
}

.close-icon {
  font-size: 48rpx;
  color: var(--text-light);
  line-height: 1;
}

/* 数据卡片 */
.data-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-light);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-icon {
  font-size: 36rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(46, 204, 113, 0.1);
  border-radius: 20rpx;
}

.card-status.online .status-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--success-color);
  border-radius: 50%;
}

.card-status.offline .status-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--text-light);
  border-radius: 50%;
}

.status-text {
  font-size: 24rpx;
  color: var(--success-color);
}

.card-status.offline .status-text {
  color: var(--text-light);
}

/* 孵化监测仪卡片 */
.incubator-card .card-body {
  margin-bottom: 24rpx;
}

.data-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.data-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-radius: var(--radius-md);
}

.data-item.temp {
  border: 2rpx solid rgba(46, 204, 113, 0.2);
}

.data-item.humidity {
  border: 2rpx solid rgba(52, 152, 219, 0.2);
}

.data-value {
  font-size: 56rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.data-value .number {
  font-size: 72rpx;
}

.data-value.temp .number {
  color: var(--primary-color);
}

.data-value.humidity .number {
  color: var(--secondary-color);
}

.unit {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.data-label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.data-precision {
  font-size: 20rpx;
  color: var(--text-light);
  background: var(--bg-secondary);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.data-divider {
  width: 2rpx;
  height: 80rpx;
  background: var(--border-color);
}

.update-time {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 24rpx;
}

/* 喂鸟器卡片 */
.food-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.food-info {
  flex: 1;
}

.food-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.food-level-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.food-level {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.food-bar {
  flex: 1;
  height: 16rpx;
  background: var(--border-color);
  border-radius: 8rpx;
  overflow: hidden;
}

.food-progress {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 8rpx;
  transition: width 0.3s;
}

.food-alert {
  padding: 12rpx 24rpx;
  background: rgba(39, 174, 96, 0.1);
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: var(--success-color);
}

.food-alert.warning {
  background: rgba(243, 156, 18, 0.1);
  color: var(--warning-color);
}

.feed-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 投喂控制 */
.feed-control {
  padding: 24rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
}

.control-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  text-align: center;
}

.control-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.feed-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
  font-size: 48rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.feed-amount {
  min-width: 200rpx;
  text-align: center;
}

.amount-value {
  font-size: 72rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.amount-unit {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.btn-icon {
  margin-right: 8rpx;
}

/* 设备列表 */
.device-list {
  display: flex;
  flex-direction: column;
}

.device-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

.device-item:last-child {
  margin-bottom: 0;
}

.device-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.device-info {
  flex: 1;
}

.device-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.device-status {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.device-status.online {
  background: rgba(39, 174, 96, 0.1);
  color: var(--success-color);
}

.device-status.offline {
  background: rgba(149, 165, 166, 0.1);
  color: var(--text-light);
}

.device-arrow {
  font-size: 48rpx;
  color: var(--text-light);
}

/* 快捷功能入口 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 32rpx;
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  transition: all 0.3s;
}

.quick-item:active {
  transform: scale(0.95);
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}
