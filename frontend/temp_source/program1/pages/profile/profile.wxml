<!--pages/profile/profile.wxml-->
<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar">
    <view class="navbar-content">
      <text class="navbar-title">伴鸟 · 个人中心</text>
      <view class="settings-icon" bindtap="gotoSettings">
        <text>⚙️</text>
      </view>
    </view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="user-section">
    <view class="user-card">
      <view class="user-main">
        <view class="user-avatar">
          <image src="{{userInfo.avatar || 'https://via.placeholder.com/160?text=Avatar'}}" mode="aspectFill"></image>
          <view class="vip-badge" wx:if="{{userInfo.isVip}}">
            <text class="vip-text">VIP</text>
          </view>
        </view>
        <view class="user-info">
          <view class="user-name-row">
            <text class="user-name">{{userInfo.nickname || '伴鸟用户'}}</text>
            <view class="user-id">
              <text>ID: {{userInfo.id || 'BN88888'}}</text>
            </view>
          </view>
          <view class="user-stats">
            <view class="stat-item">
              <text class="stat-value">{{userInfo.deviceCount || 3}}</text>
              <text class="stat-label">设备</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
              <text class="stat-value">{{userInfo.consultCount || 12}}</text>
              <text class="stat-label">问诊</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
              <text class="stat-value">{{userInfo.days || 88}}</text>
              <text class="stat-label">守护天数</text>
            </view>
          </view>
        </view>
      </view>
      <view class="user-footer">
        <view class="device-list">
          <view class="device-item">
            <text class="device-icon">🌡️</text>
            <text class="device-name">智能孵化仪</text>
          </view>
          <view class="device-item">
            <text class="device-icon">🍽️</text>
            <text class="device-name">智能喂鸟器</text>
          </view>
          <view class="device-item">
            <text class="device-icon">📷</text>
            <text class="device-name">智能摄像头</text>
          </view>
        </view>
        <view class="device-more" bindtap="manageDevices">
          <text>管理设备</text>
          <text class="arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务订阅卡片 -->
  <view class="subscription-section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">💎</text>
        <text>服务订阅</text>
      </view>
      <text class="section-desc">解锁更多专业服务</text>
    </view>

    <view class="subscription-card">
      <!-- 订阅对比 -->
      <view class="plan-compare">
        <view 
          class="plan-item {{selectedPlan === 'basic' ? 'active' : ''}}" 
          bindtap="selectPlan"
          data-plan="basic"
        >
          <view class="plan-header">
            <text class="plan-name">基础监测版</text>
            <view class="plan-badge basic">
              <text>免费</text>
            </view>
          </view>
          <view class="plan-price">
            <text class="price-value">¥0</text>
            <text class="price-period">/永久</text>
          </view>
          <view class="plan-features">
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">实时温湿度监测</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">基础数据记录</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">设备远程控制</text>
            </view>
          </view>
        </view>

        <view 
          class="plan-item {{selectedPlan === 'premium' ? 'active' : ''}}" 
          bindtap="selectPlan"
          data-plan="premium"
        >
          <view class="plan-header">
            <text class="plan-name">深度健康管理版</text>
            <view class="plan-badge premium">
              <text>推荐</text>
            </view>
          </view>
          <view class="plan-price">
            <text class="price-value">¥99</text>
            <text class="price-period">/年</text>
          </view>
          <view class="plan-features">
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">基础版所有功能</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">AI健康自检</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">定期健康检测包</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">专属健康顾问</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">问诊折扣优惠</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✓</text>
              <text class="feature-text">7×24小时客服</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 深度版权益 -->
      <view class="premium-benefits" wx:if="{{selectedPlan === 'premium'}}">
        <view class="benefits-title">
          <text class="title-icon">🎁</text>
          <text>深度版专属权益</text>
        </view>
        <view class="benefits-list">
          <view class="benefit-item">
            <view class="benefit-icon">📦</view>
            <view class="benefit-content">
              <text class="benefit-name">定期健康检测包邮寄</text>
              <text class="benefit-desc">每季度免费寄送专业健康检测包，包含便检卡、消毒用品等</text>
            </view>
          </view>
          <view class="benefit-item">
            <view class="benefit-icon">👨‍⚕️</view>
            <view class="benefit-content">
              <text class="benefit-name">专属健康顾问</text>
              <text class="benefit-desc">一对一健康顾问，提供饲养指导、疾病预防等专属服务</text>
            </view>
          </view>
          <view class="benefit-item">
            <view class="benefit-icon">💰</view>
            <view class="benefit-content">
              <text class="benefit-name">全年多次问诊折扣</text>
              <text class="benefit-desc">全年问诊8折优惠，紧急情况优先响应</text>
            </view>
          </view>
          <view class="benefit-item">
            <view class="benefit-icon">📊</view>
            <view class="benefit-content">
              <text class="benefit-name">高级数据分析报告</text>
              <text class="benefit-desc">AI生成深度健康分析报告，提供个性化养护建议</text>
            </view>
          </view>
          <view class="benefit-item">
            <view class="benefit-icon">🎓</view>
            <view class="benefit-content">
              <text class="benefit-name">专家在线课程</text>
              <text class="benefit-desc">免费参加专家讲座和在线课程，学习专业饲养知识</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 订阅按钮 -->
      <button 
        class="subscribe-btn {{selectedPlan === 'premium' ? 'premium' : ''}}" 
        bindtap="handleSubscribe"
      >
        <text wx:if="{{selectedPlan === 'basic' && !userInfo.isVip}}">切换到基础版</text>
        <text wx:elif="{{selectedPlan === 'basic' && userInfo.isVip}}">已订阅基础版</text>
        <text wx:else>立即开通深度版</text>
      </button>
    </view>
  </view>

  <!-- 功能菜单列表 -->
  <view class="menu-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="gotoDevice">
        <view class="menu-left">
          <view class="menu-icon device-icon">
            <text>🔧</text>
          </view>
          <text class="menu-text">设备配网</text>
        </view>
        <view class="menu-right">
          <text class="menu-tips" wx:if="{{deviceStatus.unconfigured > 0}}">{{deviceStatus.unconfigured}}台待配置</text>
          <text class="menu-arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="gotoOrders">
        <view class="menu-left">
          <view class="menu-icon order-icon">
            <text>📋</text>
          </view>
          <text class="menu-text">我的订单</text>
        </view>
        <view class="menu-right">
          <view class="menu-badge" wx:if="{{orderCount > 0}}">
            <text>{{orderCount}}</text>
          </view>
          <text class="menu-arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="gotoRecovery">
        <view class="menu-left">
          <view class="menu-icon recovery-icon">
            <text>📈</text>
          </view>
          <text class="menu-text">康复追踪打卡</text>
        </view>
        <view class="menu-right">
          <text class="menu-tips">连续打卡{{recoveryDays}}天</text>
          <text class="menu-arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="gotoReports">
        <view class="menu-left">
          <view class="menu-icon report-icon">
            <text>📊</text>
          </view>
          <text class="menu-text">健康报告</text>
        </view>
        <view class="menu-right">
          <text class="menu-arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="gotoSupport">
        <view class="menu-left">
          <view class="menu-icon support-icon">
            <text>💬</text>
          </view>
          <text class="menu-text">联系客服</text>
        </view>
        <view class="menu-right">
          <text class="menu-tips">7×24小时</text>
          <text class="menu-arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="gotoAbout">
        <view class="menu-left">
          <view class="menu-icon about-icon">
            <text>ℹ️</text>
          </view>
          <text class="menu-text">关于伴鸟</text>
        </view>
        <view class="menu-right">
          <text class="menu-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">
      <text>退出登录</text>
    </button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>伴鸟 v1.0.0</text>
  </view>
</view>
